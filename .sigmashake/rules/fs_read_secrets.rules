# fs_read_secrets.rules
# Technology: fs | Capability: read | Description: Prevents AI agent from reading secrets

rule block-secret-reads {
  enabled true
  priority 100
  severity error
  DENY read
  IF path GLOB "**/.env*"
  OR path GLOB "**/.aws/credentials"
  OR path GLOB "**/.ssh/id_rsa*"
  OR path GLOB "**/secrets.json"
  MESSAGE "Pro Protection: Reading local secrets, environment variables, or private keys is prohibited."
}